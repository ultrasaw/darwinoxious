{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "*": "ask",
      "@PROJECTS_DIR@/**": "allow",
      "@HOME@/go/**": "allow",
      "/tmp/**": "allow"
    },
    "bash": {
      "*": "allow",
      "sudo *": "ask",
      "gcloud *": "ask",
      "firebase *": "ask"
    }
  },
  "experimental": {
    "disable_paste_summary": true
  }
}
